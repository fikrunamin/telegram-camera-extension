{
  "manifest_version": 3,
  "name": "Telegram Camera",
  "version": "1.4.0",
  "description": "Ambil foto langsung dari Telegram Web (k & a), menyatu dengan menu attachment. Ganti kamera, self-timer, rasio, mirror.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.telegram.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.telegram.org/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.telegram.org/*"
      ],
      "js": ["injected.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["camera.html", "camera-page.js", "camera-page.css", "icons/*.png"],
      "matches": ["https://web.telegram.org/*"]
    }
  ]
}
